{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["server:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Frontend (React)",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start"],
      "port": 3000
    }
  ]
}
